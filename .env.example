NODE_ENV=development
PORT=5000

DATABASE_URL="mysql://user:password@localhost:3306/ecom_db"

JWT_SECRET=your_jwt_secret_min_32_chars_long
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

COOKIE_SECURE=false

# Cloudinary (Dashboard → Product environment credentials)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz123456

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ecom.local
SMTP_FROM_NAME=Ecom Store

CLIENT_URL=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
